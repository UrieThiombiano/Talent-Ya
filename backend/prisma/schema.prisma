generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  username      String       @unique
  passwordHash  String
  createdAt     DateTime     @default(now())

  analyses         Analysis[]
  simulations      Simulation[]
  moduleProgress   ModuleProgress[]
  coachingSessions CoachingSession[]
}

model Analysis {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  sector       String
  country      String
  scoreGlobal  Int
  verdict      String
  resultJson   Json

  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model Simulation {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  poste        String
  sector       String
  score        Int
  decision     String
  feedbackJson Json

  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model ModuleProgress {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  moduleId   String
  completedAt DateTime @default(now())

  @@unique([userId, moduleId])
}

model CoachingSession {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Contexte initial
  cv            String
  letter        String?
  offer         String
  sector        String
  sectorName    String
  country       String
  prenom        String

  // État + conversation
  state         String   // "questioning" | "ready" | "finalized"
  questions     Json     // [{q, tip, focus, a}, ...]
  questionIndex Int      @default(0)

  // Livrable final
  deliverable   Json?

  createdAt     DateTime  @default(now())
  finalizedAt   DateTime?

  @@index([userId, createdAt])
}
