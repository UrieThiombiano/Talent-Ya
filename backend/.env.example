# PostgreSQL — local OU Render Internal Database URL
DATABASE_URL="postgresql://user:password@localhost:5432/talent_ya?schema=public"

# JWT — génère une chaîne aléatoire forte (32+ caractères)
# Sur Linux/Mac : openssl rand -base64 32
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"

# Clé API Anthropic (depuis console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-api03-..."

# URL du frontend (en prod : ton URL Vercel)
FRONTEND_URL="http://localhost:5173"

# Port (Render fournit automatiquement le sien via process.env.PORT)
PORT=4000

NODE_ENV="development"
